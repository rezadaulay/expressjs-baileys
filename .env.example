# HTTP server port
PORT=5000

# Tenancy mode: single (default) or multi
WA_MODE=single

# Session name used when WA_MODE=single
WA_DEFAULT_SESSION=default

# Default country calling code used when phone starts with 0
WA_DEFAULT_COUNTRY_CODE=62

# Persistent storage driver: file (default, no native build) or sqlite
WA_STORAGE_DRIVER=file

# JSON file storage location used when WA_STORAGE_DRIVER=file
WA_FILE_STORE_PATH=./data/whatsapp-store.json

# SQLite database location used when WA_STORAGE_DRIVER=sqlite.
# Requires installing optional dependency: npm install better-sqlite3
WA_DB_PATH=./data/whatsapp.db

# Optional WhatsApp Web protocol version override.
# Leave empty to use the latest version recommended by Baileys.
WA_WEB_VERSION=

# Reliable incoming-message webhook (disabled by default)
WA_WEBHOOK_ENABLED=false
WA_WEBHOOK_URL=http://localhost:9999/hook
WA_WEBHOOK_SECRET=change-me
WA_WEBHOOK_TIMEOUT_MS=10000
WA_WEBHOOK_MAX_ATTEMPTS=8
WA_WEBHOOK_INCLUDE_GROUPS=false
WA_WEBHOOK_INCLUDE_FROM_ME=false
WA_WEBHOOK_PROCESS_APPEND=true
