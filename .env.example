# HTTP server port
PORT=5000

# Tenancy mode: single (default) or multi
WA_MODE=single

# Session name used when WA_MODE=single
WA_DEFAULT_SESSION=default

# Default country calling code used when phone starts with 0
WA_DEFAULT_COUNTRY_CODE=62

# SQLite database location
WA_DB_PATH=./data/whatsapp.db

# Optional WhatsApp Web protocol version override.
# Leave empty to use the latest version recommended by Baileys.
WA_WEB_VERSION=
