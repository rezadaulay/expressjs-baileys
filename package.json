{
  "name": "whatsapp-server",
  "version": "1.0.0",
  "description": "Simple WhatsApp API server using Baileys",
  "type": "module",
  "main": "src/index.ts",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
