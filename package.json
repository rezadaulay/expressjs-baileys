{
  "name": "whatsapp-server",
  "version": "1.0.0",
  "description": "Simple WhatsApp API server using Baileys",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "WA_STORAGE_DRIVER=file WA_FILE_STORE_PATH=/tmp/whatsapp-server-test-store-$$.json tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "baileys": "7.0.0-rc13",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "pino": "^9.6.0",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.5",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "license": "MIT"
}
